{
	"name": "datastory-clean",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:gh-pages": "BASE_PATH=/datastory-clean vite build",
		"data:sample": "npx tsx src/scripts/pipeline.ts src/data/Daten_Werte_Sensoren_sample.csv src/data/rows.sample.json src/data/columns.sample.json && npx tsx src/scripts/mapper.ts src/data/columns.sample.json src/data/charts.sample.json",
		"data:full": "npx tsx src/scripts/pipeline.ts src/data/Daten_Werte_Sensoren.csv src/data/rows.full.json src/data/columns.full.json && npx tsx src/scripts/mapper.ts src/data/columns.full.json src/data/charts.full.json",
		"data:all": "npm run data:sample && npm run data:full",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"style": "node tasks/style-dictionary.js"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@rollup/plugin-dsv": "^4.0.0",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.8",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.8",
		"autoprefixer": "^10.5.2",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"playwright": "^1.60.0",
		"postcss": "^8.5.16",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"style-dictionary": "^5.5.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"svelte-preprocess": "^6.0.5",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vite-plugin-svgstring": "^1.0.0",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@elekcsv/core": "^1.1.1",
		"d3": "^7.9.0"
	}
}
